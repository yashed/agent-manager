    "@types/react": "19.2.14"
  },
  "dependencies": {
    "@asgardeo/react": "0.22.4",
    "@agent-management-platform/eslint-config": "workspace:*",
    "date-fns": "4.1.0",
    "zod": "4.3.6"
  }
}

