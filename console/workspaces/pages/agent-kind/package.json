{
  "name": "@agent-management-platform/agent-kind",
  "version": "1.0.0",
  "type": "module",
  "import": "./dist/index.js",
  "require": "./dist/index.js",
  "types": "dist/index.d.ts",
  "baseUrl": ".",
  "sideEffects": [
    "**/*.*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "/dist"
  ],
  "scripts": {
    "format": "prettier --write --parser typescript '**/*.{ts,tsx}'",
    "lint": "eslint --config ./eslint.config.js",
    "test": "vitest run",
    "test-watch": "vitest",
    "test:ui": "vitest --ui",
    "clean": "rm -rf dist",
    "copy-assets": "find src -type f \\( -name '*.css' -o -name '*.scss' -o -name '*.less' -o -name '*.woff*' -o -name '*.ttf' -o -name '*.eot' \\) -exec sh -c 'mkdir -p dist/$(dirname {}| sed \"s|^src||\") && cp {} dist/$(dirname {}| sed \"s|^src||\")/$(basename {})' \\;",
    "build": "rushx clean && tsc -project tsconfig.lib.json && rushx copy-assets",
    "dev": "rushx clean && rushx copy-assets && tsc -project tsconfig.lib.json --watch"
  },
  "keywords": [
    "ai",
    "agents",
    "page",
    "react"
  ],
  "author": "",
  "license": "Apache-2.0",
  "description": "Agent Kind pages for organization and agent levels",
  "dependencies": {
    "react-dom": "19.1.1",
    "react-router-dom": "6.28.0",
    "@mui/material": "7.0.0",
    "@mui/icons-material": "7.0.0",
    "@emotion/react": "11.13.5",
    "@emotion/styled": "11.13.5",
    "@wso2/oxygen-ui": "0.10.1",
    "@wso2/oxygen-ui-icons-react": "0.10.1",
    "@monaco-editor/react": "4.7.0",
    "@agent-management-platform/views": "workspace:*",
    "@agent-management-platform/types": "workspace:*",
    "@agent-management-platform/shared-component": "workspace:*",
    "@agent-management-platform/api-client": "workspace:*",
    "date-fns": "4.1.0"
  },
  "devDependencies": {
    "@types/jest": "29.5.14",
    "@testing-library/jest-dom": "6.6.3",
    "@types/node": "24.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.1.9",
    "eslint": "9.36.0",
    "typescript": "5.9.3",
    "vite": "6.3.5",
    "@vitejs/plugin-react": "5.0.4",
    "vite-plugin-dts": "4.5.4",
    "vitest": "3.1.3",
    "@agent-management-platform/eslint-config": "workspace:*",
    "@eslint/eslintrc": "3.3.1"
  },
  "peerDependencies": {
    "react": "19.1.1"
  }
}
