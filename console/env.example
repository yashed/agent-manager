# Environment variables for Agent Management Console
# Copy this file to .env and adjust values for your local setup:
#   cp env.example .env

# OAuth / Thunder (Asgardeo V2) — used by envsubst on config.template.js
AUTH_CLIENT_ID=amp-console-client
AUTH_BASE_URL=http://thunder.amp.localhost:8080
AUTH_SCOPES=openid profile email
SIGN_IN_REDIRECT_URL=http://localhost:3000/login
SIGN_OUT_REDIRECT_URL=http://localhost:3000/login
VALIDATE_ID_TOKEN=false
CLOCK_TOLERANCE=300

# API Configuration
API_BASE_URL=http://localhost:9000
OBS_API_BASE_URL=http://localhost:9098
GATEWAY_CONTROL_PLANE_URL=http://localhost:9243
GATEWAY_VERSION=v0.11.0

# Observability / Instrumentation
INSTRUMENTATION_URL=http://localhost:22893/otel

# Guardrails Configuration
GUARDRAILS_CATALOG_URL=https://db720294-98fd-40f4-85a1-cc6a3b65bc9a-prod.e1-us-east-azure.choreoapis.dev/api-platform/policy-hub-api/policy-hub-public/v1.0/policies?categories=Guardrails,AI&limit=100
GUARDRAILS_DEFINITION_BASE_URL=https://db720294-98fd-40f4-85a1-cc6a3b65bc9a-prod.e1-us-east-azure.choreoapis.dev/api-platform/policy-hub-api/policy-hub-public/v1.0/policies
GUARDRAIL_CAP_AWS_BEDROCK=false
GUARDRAIL_CAP_AZURE_CONTENT_SAFETY=false
GUARDRAIL_CAP_GRANITE_GUARDIAN=false
GUARDRAIL_CAP_NEMO_GUARD=false
GUARDRAIL_CAP_SEMANTIC_GUARDRAILS=false

# Authentication
DISABLE_AUTH=false

